[nation_amazigh]

name   = _("Amazigh")
plural = _("?plural:Imazighen")
groups = "Medieval", "African"
legend = _("The Amazigh civilization is one of the oldest in the Mediterranean\
 Basin, co-existing with ancient Egypt. The Imazighen people, which means\
 \"free men\", are sturdy and strong but cheerful and\
 generous with a great consideration for family and tribe.\
 Every tribe has its own traditions and culture, which is the reason for the\
 countless diversity of traditions in modern Morocco, Algeria, and Tunisia.\
 The Imazighen speak old languages such as Tamazirt, Tachelhit or Tarifit,\
 collectively known as Berber languages,\
 using an age-old writing system called Tifinagh.")

leaders = {
 "name",                "sex"

; Son of Syphax, Last King of Massaessyle (Occidental Numidia) before
; unification. Reigned 203BC-200BC after his father, but resigned to Romans
; by 200BC.
 "Vermina",             "Male"

; King of the Massyles (Oriental Numidia).
 "Niptasan",            "Male"

; Son of Niptasan, King of the Massyles (Oriental Numidia).
 "Zilalsan",            "Male"

; Son of Zilalsan, Last King of the Massyles (Oriental Numidia) before
; unification. died 208BC.
 "Gaïa",                "Male"

; (238BC-148BC) son of Gaïa, unified Massyles and Massaessyle to found
; Numidia in 202BC. reigned 208BC/148BC.
 "Masinissa",           "Male"

; son of Mastanabal son of Masinissa, reigned 111BC-105BC.
 "Jugurthen",           "Male"

; (85BC-46BC) son of Hiempsal II, last king of the free Amazigh Numdia.
; reigned 60BC-46BC.
 "Juba I",              "Male"

; son of Juba II, Vassal King of Mauritania, the Roman Numidia, married
; Cleopatra Selene II (40BC-6AC), daughter of Cleopatra, reigned 52BC-23BC.
 "Juba II",             "Male"

; Berber: Tiqfarin
; Amazigh General in the Roman Army, after Roman empire weakens, he unified
; the amazigh tribes and conquerred a part of Numidia between 17Ac-24AC.
 "Tacfarinas",          "Male"

; Ptolemy of Mauretania
; (1AC-40AC) son of Juba II and Cleopatra Selene II, the last King of
; Mauretania, Conquered Takfarinas revolt and Garamantes Rebellion.
; reigned 23AC-40AC.
 "Ptolemaeus",          "Male"

; Amazigh Umayyad General, he Conquered Al-Andalus, d. 720
 "Tariq Ibn Ziad",      "Male"

; (1006-1106), founder of the Amazigh Almoravides sunnites dynasty, governs
; over Morocco, Mauritania, west Algeria, Sénégal, Al-Andalus and a part of
; Portugal.
 "Youssef Ibn Tachfin", "Male"
}

