[nation_westernpomeranian]

name   = _("Western Pomeranian")
plural = _("?plural:Western Pomeranians")
groups = "European", "Medieval"
legend = _("Western Pomerania is a geographical and historical region in\
 North West Poland and the extreme North East of Germany. Initially an\
 independent Slavic state, Western Pomerania was twice conquered by the\
 Polish. Later, Western Pomerania succumbed to Germanization and was\
 divided into smaller feudal principalities which were gradually conquered\
 by Brandenburg. For many years this land was part of Germany but in 1945\
 it was attached to Poland.")

