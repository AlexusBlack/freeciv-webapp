legend = _("The Slavs are a modern linguistic group of several nations in\
 Eastern Europe with common historical roots.\
 The origin of the Slavs is not known precisely, therefore there are many\
 hypotheses trying to explain them.\
 Their sudden appearance in the history of civilized Europe may be related\
 to the arrival of Iranian peoples and the expansion of the Huns.")

leaders = {
 "name",                "sex"
 "Boz",                 "Male"   ; Ruler of Ants, probably Sarmatian,
                                 ; murdered by the Goths, mentioned in
                                 ; the chronicle of Jordanes
 "Boleslavŭ Xorbrŭjĭ",  "Male"   ; Polish king Bolesław Chrobry
 "Voldislavŭ",          "Male"   ; Włodzisław, Lendian prince
 "Radogostĭ",           "Male"   ; Leader of Sclaveni, in greek sources
                                 ; known as Ardagast
 "Svętoslavŭ",          "Male"   ; Svyatoslav Veliky, grand prince of Kiev
 "Jaroslavŭ Mądrŭjĭ",   "Male"   ; Jaroslav Mudry, grand prince of Kiev
 "Boguxvalŭ",           "Male"
 "Kyjŭ",                "Male"   ; Legendary founder of Kiev
 "Poznanŭ",             "Male"   ; Legendary founder of Poznan city
                                 ; in Greater Poland
}

