[nation_californian]

name   = _("Californian")
plural = _("?plural:Californians")
groups = "American"
legend = _("California is the largest US state by population and economy.\
 First populated by Native Americans, it was colonized by Spanish\
 missionaries in the 18th century. California became a territory of\
 Mexico upon that country's independence. During the Mexican-American War\
 local American settlers proclaimed the \'Bear Flag Republic\', which was\
 incorporated into the United States shortly thereafter. The 1848 Gold\
 Rush brought massive numbers of immigrants to California. In the 20th\
 century the state became a center of the world's entertainment and\
 technology industries.")

leaders = {
 "name",                  "sex"
 "Junípero Serra",        "Male" ; Missionary
 "William B. Ide",        "Male" ; Commander of California Republic
 "John C. Frémont",       "Male" ; Conqueror and military governor
 "Joaquin Murrieta",      "Male" ; Outlaw
 "Leland Stanford",       "Male" ; Tycoon and governor
 "Norton I",              "Male" ; Self declared emperor of the United States
 "Hiram Johnson",         "Male" ; Progressive politican and governor
 "Earl Warren",           "Male" ; US Supreme Court justice and governor
 "Ronald Reagan",         "Male" ; Actor, governor and president of the
                                 ; United States
 "Arnold Schwarzenegger", "Male" ; Governator
