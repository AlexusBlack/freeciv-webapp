[nation_goldenhorde]

name   = _("Golden Horde")
plural = _("?plural:Golden Horde")
groups = "European", "Asian", "Medieval"
legend = _("The Golden Horde was a historical Mongol and Tatar state,\
 founded around 1240 in the western part of the empire of Genghis Khan by\
 his grandson Batu Khan, with its capital at Sarai Batu. After the\
 conquests its greatest extent covered the territories from the Irtysh to\
 the mountains of the Caucasus, Black Sea and the Volga and Kama basins.\
 In 1375 the whole country was conquered by Tamerlane and\
 became vassalized. From the 14th century the country gradually\
 descended into instability, which at the beginning of the 15th century\
 led to the complete disintegration of the state.")

