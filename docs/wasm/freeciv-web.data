[nation_volgagerman]

name   = _("Volga German")
plural = _("?plural:Volga Germans")
groups = "European"
legend = _("The Volga Germans were ethnic Germans who lived along the River\
 Volga in Southern Russia, around the city of Saratov and to the South.\
 They were recruited as immigrants in the 18th century. The Russian\
 authorities allowed them to cultivate their German language and\
 traditions. From 1918 to 1941 there was a Volga German ASSR within the\
 Soviet Union. After the attack of the Third Reich in the USSR, the\
 autonomous republic was abolished by a decree of Stalin. Volga Germans\
 were sent to other parts of the Soviet Union, mainly to Kazakhstan and\
 Siberia.")

