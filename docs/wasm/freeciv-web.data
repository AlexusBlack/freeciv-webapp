[nation_holyroman]

name   = _("Holy Roman")
plural = _("?plural:Holy Romans")
groups = "Medieval", "Early Modern", "European"

legend = _("The Holy Roman Empire was considered the successor to the\
 Roman Empire, but as Voltaire once quipped it was neither Holy, nor Roman\
 nor even less an Empire. Nonetheless it proved to be extremely durable, and\
 lost territory only very slowly. For most of its existence it was a\
 complex patchwork consisting of an uncountable number of counties,\
 duchies, electorates, imperial free cities and other territories. In 1806\
 it was dissolved by Napoleon and replaced by the Confederation of the\
 Rhine.")

