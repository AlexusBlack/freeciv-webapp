## Process this file with automake to produce Makefile.in

## Override automake so that "make install" puts these in proper place:
pkgdatadir = $(datadir)/$(PACKAGE)/default

pkgdata_DATA =          \
	ai_effects.ruleset \
	default.lua	\
	nationlist.ruleset

EXTRA_DIST = $(pkgdata_DATA)
