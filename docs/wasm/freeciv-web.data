groups = "Asian", "Early Modern", "Modern"
legend = _("The Islamic State, also known as ISIS or ISIL, emerged in 2014 during the Syrian civil war, declaring a self-proclaimed caliphate. Rooted in extremist interpretations of Sunni Islam, it aimed to establish a global theocratic state. The group controlled vast territories across Syria and Iraq, enforcing strict Sharia law and committing widespread atrocities, including genocide and terrorism. A global coalition led by the US, alongside local forces, defeated ISIS territorially by 2019, though its ideology persists in cells worldwide.")

