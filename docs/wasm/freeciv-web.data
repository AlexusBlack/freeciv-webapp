[nation_piedmontese]

name   = _("Piedmontese")
plural = _("?plural:Piedmontese")
groups = "European", "Early Modern"
legend = _("Piedmont was formed when the Duchy of Savoy elevated itself to\
 the status of a kingdom in 1720. Officially it was a constituent part of\
 the Kingdom of Sardinia-Piedmont. The area was occupied by Napoleon in\
 1796 but reasserted its independence in 1814. Sardinia-Piedmont was one\
 of the leading states of the Risorgimiento, Italy's national rebirth. In\
 1861 it was merged into the newly formed kingdom of Italy, the last\
 Piedmontese king becoming the first king of Italy. Currently it is one\
 of the regions of Italy.")

