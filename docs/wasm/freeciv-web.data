plural = _("?plural:Langobards")
groups = "Ancient", "Medieval", "European"
legend = _("The Langobards were an ancient Germanic people. They originated\
 from Scandinavia but settled in the area on the lower Elbe. In 166 CE\
 they participated in the attack on the Roman provinces of Pannonia and\
 Noricum. Their first state was established on the Danube. Having defeated\
 the Gepids in an alliance with the Avars, the Langobards under king\
 Alboin invaded Italia in 568. They founded a new kingdom\
 with its capital in Pavia. The modern region of Lombardy derives its name\
 from the Lombards.")

