[nation_akwe]

name   = _("Akwe")
plural = _("?plural:Akwe")
groups = "American"

legend = _("The Akwe are also known by three different tribal names in\
 Portuguese, Xavante, Xakriaba and Xerente. They have a patrilineal clan\
 system and live in Mato Grosso and Tocantins states of Brazil, though\
 they have been forced to move by Brazilians several times through their\
 history. Traditionally, they are ruled by councils of elders who elect a\
 chief and have likely lived in large ring villages since about the 9th\
 century CE. They are Ge speakers who farm maize, manioc, sweet potatoes\
 and yams.")

