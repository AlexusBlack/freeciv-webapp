[nation_moravian]

name   = _("Moravian")
plural = _("?plural:Moravians")
groups = "Medieval", "European"
legend = _("Great Moravia was a Slavic medieval monarchy whose center was\
 located in the areas of modern Moravia region in Czech Republic. Moravia\
 conquered areas of Bohemia, Slovakia, Pannonia and large parts of\
 southern Poland and Lusatia. The first ruler and founder of this state\
 was duke Mojmir I. The Great Moravian state was destroyed as a result\
 of the Hungarian invasion from the eastern steppes. After the defeat of the\
 Hungarians by the Holy Roman Empire, Moravia was turned into a\
